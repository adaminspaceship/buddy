{
  "name": "@adaminspaceship/buddy",
  "version": "0.20.2",
  "description": "OpenClaw plugin: receives audio from the Buddy iOS app, transcribes it (BYOK), and dispatches the text to the active agent.",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist/**",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "publish:dry": "npm run build && clawhub package publish . --family bundle-plugin --dry-run",
    "publish:clawhub": "npm run build && clawhub package publish . --family bundle-plugin",
    "prepublishOnly": "npm run build"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": "*",
      "minGatewayVersion": "0.0.0"
    },
    "build": {
      "openclawVersion": "2026.5.4"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": false
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/adaminspaceship/buddy.git",
    "directory": "openclaw-plugin"
  },
  "homepage": "https://github.com/adaminspaceship/buddy#readme",
  "license": "MIT",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "voice",
    "transcription",
    "ios",
    "buddy"
  ],
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "busboy": "^1.6.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.10"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20"
  }
}